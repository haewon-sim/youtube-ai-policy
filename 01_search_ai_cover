def request_search_page(
    api_key: str,
    query: str,
    published_after: str,
    published_before: str,
    max_results: int,
    page_token: str = "",
    session: Optional[requests.Session] = None,
) -> Dict:
    """
    YouTube search.list API를 호출합니다.

    order=date 정렬을 사용하는 이유:
      - relevance 정렬은 알고리즘 편향으로 인기 영상이 과대 대표됨
      - date 정렬이 연구 표본의 시간적 대표성에 더 유리
    """
    params = {
        "key":             api_key,
        "part":            "snippet",
        "q":               query,
        "type":            "video",
        "order":           "date",
        "publishedAfter":  published_after,
        "publishedBefore": published_before,
        "maxResults":      max_results,
    }
    if page_token:
        params["pageToken"] = page_token

    requester = session or requests
    response  = requester.get(API_URL, params=params, timeout=30)
    response.raise_for_status()
    return response.json()


# ═══════════════════════════════════════════════════════════════
# 응답 파싱
# ═══════════════════════════════════════════════════════════════

def parse_search_items(
    items: List[Dict],
    window_start: str,
    window_end: str,
    collected_at_utc: str,
) -> List[Dict]:
    """
    search.list 응답에서 필요한 컬럼만 추출합니다.

    title, description 등을 여기서 수집하지 않는 이유:
      search.list 결과의 메타데이터는 불완전(잘린 description 등)
      → STEP 2(videos.list)에서 정확한 값으로 확정
    """
    rows: List[Dict] = []

    for item in items:
        id_obj  = item.get("id", {}) or {}
        snippet = item.get("snippet", {}) or {}

        video_id   = id_obj.get("videoId", "").strip()
        channel_id = snippet.get("channelId", "").strip()

        # video_id 없는 항목(채널, 플레이리스트 등) 제외
        if not video_id:
            continue

        rows.append({
            "video_id":            video_id,
            "channel_id":          channel_id,
            "search_window_start": window_start,
            "search_window_end":   window_end,
            "collected_at_utc":    collected_at_utc,
        })

    return rows


# ═══════════════════════════════════════════════════════════════
# CSV 저장
# ═══════════════════════════════════════════════════════════════

def append_rows(output_path: str, rows: List[Dict]) -> int:
    """수집된 행을 CSV에 추가합니다."""
    if not rows:
        return 0
    with open(output_path, "a", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_COLUMNS)
        writer.writerows(rows)
    return len(rows)


# ═══════════════════════════════════════════════════════════════
# 쿼터 초과 감지
# ═══════════════════════════════════════════════════════════════

def is_quota_exceeded(exc: requests.HTTPError) -> bool:
    """
    quotaExceeded 에러를 감지합니다.
    감지 즉시 수집을 중단하여 API 키 차단을 방지합니다.
    """
    try:
        text = exc.response.text.lower()
    except Exception:
        text = str(exc).lower()
    return "quotaexceeded" in text


