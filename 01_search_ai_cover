def generate_weekly_windows(
    start_date: str,
    end_date: str,
) -> List[Tuple[str, str]]:
    """
    수집 기간을 7일 단위로 분할합니다.

    7일로 분할하는 이유:
      - search.list는 하나의 쿼리+기간으로 최대 약 500개 반환
      - 7일로 쪼개면 주당 최대 500개씩 수집 가능
      - 최종 분석의 'week' 단위와 일치하여 일관성 확보

    Returns:
        [(window_start_iso, window_end_iso), ...] 리스트
        ISO 8601 형식: "2023-09-01T00:00:00Z"
    """
    start_dt      = datetime.strptime(start_date, "%Y-%m-%d")
    end_dt        = datetime.strptime(end_date, "%Y-%m-%d")
    end_exclusive = end_dt + timedelta(days=1)

    windows: List[Tuple[str, str]] = []
    current = start_dt

    while current < end_exclusive:
        next_boundary = min(current + timedelta(days=7), end_exclusive)
        windows.append((
            current.strftime("%Y-%m-%dT00:00:00Z"),
            next_boundary.strftime("%Y-%m-%dT00:00:00Z"),
        ))
        current = next_boundary

    return windows


# ═══════════════════════════════════════════════════════════════
