# 정책 구간 판별 (로그 출력용)
# ═══════════════════════════════════════════════════════════════

def get_phase(window_start: str) -> str:
    """윈도우가 어느 정책 구간에 속하는지 반환합니다."""
    date = window_start[:10]
    if date < POLICY1_ANNOUNCE:
        return "① Pre-Announce    "
    elif date < POLICY1_DATE:
        return "② Pre-Policy1     "
    elif date < POLICY2_DATE:
        return "③ Between-Policies"
    else:
        return "④ Post-Policy2    "


