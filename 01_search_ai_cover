    windows: List[Tuple[str, str]],
    completed: Set[str],
    output_path: str,
    completed_path: str,
) -> None:
    pending_count = sum(1 for w in windows if w[0] not in completed)

    print("\n" + "═" * 65)
    print("  YouTube AI Cover 시드 영상 수집")
    print("═" * 65)
    print(f"  키워드              : {SEARCH_QUERY}")
    print(f"  수집 기간           : {COLLECTION_START} ~ {COLLECTION_END}")
    print(f"  총 윈도우 수        : {len(windows)}개 (7일 단위)")
    print(f"  이미 완료된 윈도우  : {len(completed)}개 → API 요청 없이 건너뜀")
    print(f"  이번에 수집할 윈도우: {pending_count}개")
    print(f"  예상 쿼터 소모      : {pending_count * 100:,} units")
    print(f"  영상 데이터 파일    : {output_path}")
    print(f"  완료 기록 파일      : {completed_path}")
    print("─" * 65)
    print("  정책 구간")
    print(f"  ① Pre-Announce     : ~ {POLICY1_ANNOUNCE} (정책1 예고 전)")
    print(f"  ② Pre-Policy1      : {POLICY1_ANNOUNCE} ~ {POLICY1_DATE}")
    print(f"  ③ Between-Policies : {POLICY1_DATE} ~ {POLICY2_DATE}")
    print(f"  ④ Post-Policy2     : {POLICY2_DATE} ~")
    print("═" * 65 + "\n")


# ═══════════════════════════════════════════════════════════════
# 메인 실행
# ═══════════════════════════════════════════════════════════════

def main() -> None:
    args = parse_args()
    validate_args(args)

    # reset 모드: 기존 파일 삭제 후 처음부터
    if args.reset:
        print("\n[RESET] 기존 파일을 삭제하고 처음부터 수집합니다.")
        reset_output_files(args.output, args.completed_windows)

    # 7일 단위 윈도우 생성 (28개월 전체)
    windows = generate_weekly_windows(COLLECTION_START, COLLECTION_END)

    # ─────────────────────────────────────────────────────────
    # 완료된 윈도우 로드
    # 핵심: 이 집합에 있는 윈도우는 API 요청 자체를 건너뜁니다.
    # API 키가 바뀌어도 이 파일은 유지됩니다.
    # ─────────────────────────────────────────────────────────
    completed_windows = load_completed_windows(args.completed_windows)

    # CSV 헤더 초기화 (파일이 없을 때만)
    ensure_csv_header(args.output)

    print_plan(windows, completed_windows, args.output, args.completed_windows)

    # 수집 통계
    total_requests    = 0
    total_saved       = 0
    windows_skipped   = 0
    windows_completed = 0
    windows_error     = 0

    session = requests.Session()

    try:
        for window_idx, (window_start, window_end) in enumerate(windows, start=1):

            phase = get_phase(window_start)

            # ─────────────────────────────────────────────────
            # 핵심 로직: 완료된 윈도우 건너뛰기
            #
            # completed_windows.txt에 기록된 윈도우는
            # API 요청 없이 즉시 다음 윈도우로 넘어갑니다.
            # 이것이 이전 방식(응답 받은 후 중복 체크)과의 차이점입니다.
            # ─────────────────────────────────────────────────
            if window_start in completed_windows:
                windows_skipped += 1
                print(
                    f"[{window_idx:3d}/{len(windows)}] "
                    f"{phase} "
                    f"{window_start[:10]} → {window_end[:10]} "
                    f"| ✅ SKIP"
                )
                continue

            # 수집 대상 윈도우
            print(
                f"\n[{window_idx:3d}/{len(windows)}] "
                f"{phase} "
                f"{window_start[:10]} → {window_end[:10]}"
            )

            next_page_token = ""
            page_no         = 0
            window_saved    = 0
            window_error    = False

            # ─────────────────────────────────────────────────
            # 페이지네이션 루프
            # nextPageToken이 없을 때까지 반복 수집
            # ─────────────────────────────────────────────────
            while True:
                page_no += 1
                collected_at_utc = datetime.now(timezone.utc).isoformat()

                try:
                    data = request_search_page(
                        api_key          = args.api_key,
                        query            = SEARCH_QUERY,
                        published_after  = window_start,
                        published_before = window_end,
                        max_results      = args.max_results_per_page,
                        page_token       = next_page_token,
                        session          = session,
                    )
                    total_requests += 1

                except requests.HTTPError as exc:
                    status = getattr(exc.response, "status_code", "unknown")
                    print(f"  [ERROR] HTTP {status}: {exc}")

                    if is_quota_exceeded(exc):
                        # 쿼터 초과: 즉시 중단
                        # 현재 윈도우는 완료 기록 안 됨 → 다음 실행 시 재수집
                        print(
                            "\n  [STOP] ❌ 쿼터 초과 감지. 즉시 중단합니다.\n"
                            f"  현재 윈도우({window_start[:10]})는 "
                            "완료 기록되지 않았으므로\n"
                            "  내일 다시 실행하면 이 윈도우부터 이어서 수집됩니다."
                        )
                        raise

                    # 그 외 HTTP 에러: 현재 윈도우 건너뛰고 다음으로
                    window_error = True
                    break

                except requests.RequestException as exc:
                    print(f"  [ERROR] 요청 실패: {exc}")
                    window_error = True
                    break

                items = data.get("items", [])

                if not items:
                    print(f"  [PAGE {page_no}] 결과 없음")
                    break

                rows = parse_search_items(
                    items            = items,
                    window_start     = window_start,
                    window_end       = window_end,
                    collected_at_utc = collected_at_utc,
                )

                saved_now    = append_rows(args.output, rows)
                window_saved += saved_now
                total_saved  += saved_now

                has_next = bool(data.get("nextPageToken"))
                print(
                    f"  [PAGE {page_no}] "
                    f"seen={len(rows):3d}  "
                    f"saved={saved_now:3d}  "
                    f"nextPage={'yes' if has_next else 'no '}"
                )

                next_page_token = data.get("nextPageToken", "")
                if not next_page_token:
                    break

                time.sleep(args.sleep_seconds)

            # ─────────────────────────────────────────────────
            # 윈도우 완료 기록
            #
            # 에러 없이 정상 종료된 경우에만 기록합니다.
            # 기록된 윈도우는 다음 실행 시 API 요청 없이 건너뜁니다.
            # 에러가 발생한 경우 기록하지 않으므로 다음 실행 시 재수집됩니다.
            # ─────────────────────────────────────────────────
            if not window_error:
                mark_window_completed(args.completed_windows, window_start)
                completed_windows.add(window_start)  # 메모리도 업데이트
                windows_completed += 1
                print(
                    f"  → {window_saved}개 저장 "
                    f"| ✅ 완료 기록됨"
                )
            else:
                windows_error += 1
                print(
                    f"  → {window_saved}개 저장 "
                    f"| ⚠️  에러 발생 → 다음 실행 시 재수집"
                )

            time.sleep(args.sleep_seconds)

    except requests.HTTPError:
        # 쿼터 초과 시 여기서 종료
        pass

    finally:
        session.close()

    # ─────────────────────────────────────────────────────────
    # 최종 결과 출력
    # ─────────────────────────────────────────────────────────
    print("\n" + "═" * 65)
    print("  수집 결과")
    print("═" * 65)
    print(f"  총 API 요청 수        : {total_requests:,}회")
    print(f"  총 저장 항목 수       : {total_saved:,}개")
    print(f"  건너뛴 윈도우         : {windows_skipped:,}개 (이미 완료)")
    print(f"  이번에 완료된 윈도우  : {windows_completed:,}개")
    print(f"  에러 발생 윈도우      : {windows_error:,}개 (다음 실행 시 재수집)")
    print(f"  영상 데이터 파일      : {args.output}")
    print(f"  완료 기록 파일        : {args.completed_windows}")
    print("═" * 65)

    remaining = len(windows) - windows_skipped - windows_completed
    if remaining > 0:
        print(
            f"\n  ⚠️  아직 {remaining}개 윈도우가 남아있습니다.\n"
            "  다시 실행하면 이어서 수집됩니다.\n"
            "  (API 키를 바꿔도 완료된 윈도우는 재수집하지 않습니다)"
        )
    else:
        print(
            "\n  🎉 모든 윈도우 수집 완료!\n"
            "  다음 단계: python 02_fetch_videos_meta.py\n"
        )


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(
            "\n[STOPPED] 사용자에 의해 중단되었습니다.\n"
            "현재 윈도우는 완료 기록되지 않았으므로\n"
            "다시 실행하면 해당 윈도우부터 이어서 수집됩니다."
        )
        sys.exit(1)
    except Exception as exc:
        print(f"\n[FATAL] 예상치 못한 오류: {exc}")
        sys.exit(1)
