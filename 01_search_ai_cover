def reset_output_files(output_path: str, completed_path: str) -> None:
    """--reset 옵션 사용 시 기존 파일을 삭제합니다."""
    for path in [output_path, completed_path]:
        if os.path.exists(path):
            os.remove(path)
            print(f"[RESET] 삭제됨: {path}")


def ensure_csv_header(output_path: str) -> None:
    """출력 CSV 파일이 없을 때만 헤더를 작성합니다."""
    if os.path.exists(output_path):
        return
    with open(output_path, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_COLUMNS)
        writer.writeheader()


