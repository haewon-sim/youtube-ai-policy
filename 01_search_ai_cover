def load_completed_windows(filepath: str) -> Set[str]:
    """
    01_completed_windows.txt에서 완료된 윈도우 목록을 로드합니다.

    완료된 윈도우 = 모든 페이지를 정상 수집하고
                   nextPageToken=no로 종료된 윈도우

    이 함수가 반환하는 집합에 포함된 윈도우는
    다음 실행 시 API 요청 없이 즉시 건너뜁니다.

    API 키가 바뀌어도 이 파일은 그대로이므로
    완료된 윈도우는 새 키로 다시 요청하지 않습니다.

    Returns:
        {"2023-09-01T00:00:00Z", "2023-09-08T00:00:00Z", ...}
    """
    completed: Set[str] = set()
    if not os.path.exists(filepath):
        return completed

    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            window = line.strip()
            if window:
                completed.add(window)

    return completed


def mark_window_completed(filepath: str, window_start: str) -> None:
    """
    윈도우가 정상 완료됐을 때 01_completed_windows.txt에 기록합니다.

    기록 조건 (모두 충족해야 함):
      ✅ 해당 윈도우의 모든 페이지를 수집 완료
      ✅ nextPageToken이 없어서 자연스럽게 종료
      ✅ HTTP 에러나 쿼터 초과 없음

    기록되지 않는 경우:
      ❌ HTTP 에러 발생
      ❌ 쿼터 초과로 중단
      ❌ KeyboardInterrupt로 중단
    """
    with open(filepath, "a", encoding="utf-8") as f:
        f.write(window_start + "\n")


