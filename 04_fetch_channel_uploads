#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
04_fetch_channel_uploads.py

═══════════════════════════════════════════════════════════════
이 스크립트가 하는 일
═══════════════════════════════════════════════════════════════
03_channels_meta.csv의 uploads_playlist_id를 이용하여
각 채널의 전체 업로드 목록(video_id + published_at)을 수집합니다.

이 단계가 연구에서 중요한 이유:
  - 기존 채널이 정책 후에 실제로 업로드를 줄였는지 측정
    → 풍선효과 완성: 기존채널 감소 + 신규채널 증가 패턴 확인
  - 채널 생존율/이탈율 계산
    → 정책 전 AI Cover 올리던 채널이 정책 후에도 올리는지
  - 채널 전환율 계산
    → AI Cover를 그만두고 다른 콘텐츠로 바꾼 채널 비율

수집 대상:
  - is_ai_cover=1 영상이 있는 채널의 전체 업로드 목록
  - AI Cover가 아닌 영상도 포함 (채널 전체 활동 파악용)
  - 이후 STEP 5에서 video_id로 메타데이터 조회 + AI Cover 재분류

입력 파일: data/03_channels_meta.csv
출력 파일: data/04_channel_uploads.csv
           data/04_completed_channels.txt

═══════════════════════════════════════════════════════════════
Resume 방식
═══════════════════════════════════════════════════════════════
채널 단위로 완료를 기록합니다.
완료된 채널은 API 요청 없이 건너뜁니다.
API 키를 교체해도 완료된 채널은 재수집하지 않습니다.

완료 기준:
  - 해당 채널의 모든 페이지를 수집하고
  - nextPageToken이 없어서 자연 종료된 경우만 기록
  - 쿼터 초과/에러로 중단된 채널은 기록 안 함 → 다음 실행 시 재수집

═══════════════════════════════════════════════════════════════
API 키 설정
═══════════════════════════════════════════════════════════════
코드 상단 API_KEY 변수에 입력하거나
--api-key 인자로 전달하세요.

쿼터 비용: playlistItems.list 1회 = 1 unit
채널당 평균 50개 업로드 가정 → 채널당 약 1 unit
채널 4,000개 기준 → 약 4,000~20,000 units (채널당 업로드 수에 따라 변동)
"""

from __future__ import annotations

import argparse
import csv
import os
import sys
import time
from datetime import datetime, timezone
from typing import Dict, List, Optional, Set

import pandas as pd
import requests


# ═══════════════════════════════════════════════════════════════
# 설정값
# ═══════════════════════════════════════════════════════════════

API_URL = "https://www.googleapis.com/youtube/v3/playlistItems"

# ✅ 여기에 YouTube Data API 키를 입력하세요
API_KEY = "KEY"

# 입출력 파일 경로 (data 폴더 기준)
DEFAULT_INPUT_CHANNELS  = "data/03_channels_meta.csv"
DEFAULT_OUTPUT          = "data/04_channel_uploads.csv"
DEFAULT_COMPLETED       = "data/04_completed_channels.txt"

MAX_RESULTS = 50  # playlistItems.list 페이지당 최대값

# 출력 컬럼
# 최소화: video_id + channel_id + published_at 만 수집
# (제목/설명 등은 STEP 5에서 videos.list로 따로 수집)
OUTPUT_COLUMNS = [
    "channel_id",       # 채널 식별자
    "video_id",         # 영상 식별자 → STEP 5 입력값
    "published_at",     # 게시 시각 → 업로드 빈도/생존율 계산용
]


# ═══════════════════════════════════════════════════════════════
# 커맨드라인 인자
# ═══════════════════════════════════════════════════════════════

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "각 채널의 전체 업로드 목록을 수집합니다.\n"
            "채널 생존율/이탈율/전환율 분석에 필요합니다.\n"
            "\n"
            "입출력 파일은 모두 data/ 폴더를 기준으로 합니다.\n"
            "Resume 방식: 완료된 채널은 API 요청 없이 건너뜁니다."
        )
    )
    parser.add_argument(
        "--api-key",
        type=str,
        default=API_KEY,
        help="YouTube Data API 키",
    )
    parser.add_argument(
        "--input-channels",
        type=str,
        default=DEFAULT_INPUT_CHANNELS,
        help=f"채널 메타데이터 CSV (기본값: {DEFAULT_INPUT_CHANNELS})",
    )
    parser.add_argument(
        "--output",
        type=str,
        default=DEFAULT_OUTPUT,
        help=f"업로드 목록 출력 CSV (기본값: {DEFAULT_OUTPUT})",
    )
    parser.add_argument(
        "--completed",
        type=str,
        default=DEFAULT_COMPLETED,
        help=f"완료된 채널 기록 파일 (기본값: {DEFAULT_COMPLETED})",
    )
    parser.add_argument(
        "--sleep-seconds",
        type=float,
        default=0.05,
        help="API 요청 간 대기 시간(초) (기본값: 0.05)",
    )
    parser.add_argument(
        "--reset",
        action="store_true",
        default=False,
        help="처음부터 다시 수집 (기존 출력 파일 삭제)",
    )
    return parser.parse_args()


# ═══════════════════════════════════════════════════════════════
# 입력값 검증
# ═══════════════════════════════════════════════════════════════

def validate_args(args: argparse.Namespace) -> None:
    if not args.api_key or args.api_key == "여기에_API_키_입력":
        raise ValueError(
            "\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "❌ API 키가 설정되지 않았습니다.\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "방법 1. 코드 상단 API_KEY 변수에 직접 입력:\n"
            '  API_KEY = "AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"\n'
            "\n"
            "방법 2. 커맨드라인 인자로 전달:\n"
            '  python 04_fetch_channel_uploads.py --api-key "AIzaSyXXXX..."\n'
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        )
    if not os.path.exists(args.input_channels):
        raise FileNotFoundError(
            f"입력 파일을 찾을 수 없습니다: {args.input_channels}\n"
            "03_fetch_channels_meta.py를 먼저 실행하세요.\n"
            "파일이 data/ 폴더에 있는지 확인하세요."
        )


# ═══════════════════════════════════════════════════════════════
# 입력 데이터 로드
# ═══════════════════════════════════════════════════════════════

def load_channels(input_path: str) -> pd.DataFrame:
    """
    03_channels_meta.csv에서 채널 목록을 로드합니다.
    uploads_playlist_id가 비어있는 채널은 제외합니다.
    """
    df = pd.read_csv(input_path, low_memory=False)

    # uploads_playlist_id 없는 채널 제외 (삭제된 채널 등)
    before = len(df)
    df = df[df['uploads_playlist_id'].notna() &
            (df['uploads_playlist_id'].str.strip() != '')].copy()
    after = len(df)

    print(f"[INFO] 전체 채널 수          : {before:,}")
    print(f"[INFO] uploads_playlist_id 있음: {after:,}")
    if before > after:
        print(f"[INFO] playlist_id 없어 제외   : {before-after:,}개")

    return df


# ═══════════════════════════════════════════════════════════════
# 완료된 채널 관리
# ═══════════════════════════════════════════════════════════════

def load_completed_channels(filepath: str) -> Set[str]:
    """
    04_completed_channels.txt에서 완료된 channel_id를 로드합니다.

    완료된 채널 = 모든 페이지를 정상 수집하고 nextPageToken=no로 종료된 채널
    이 파일에 기록된 채널은 API 요청 없이 즉시 건너뜁니다.
    API 키가 바뀌어도 이 파일은 유지됩니다.
    """
    completed: Set[str] = set()
    if not os.path.exists(filepath):
        return completed
    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            ch = line.strip()
            if ch:
                completed.add(ch)
    return completed


def mark_channel_completed(filepath: str, channel_id: str) -> None:
    """채널이 정상 완료됐을 때 channel_id를 기록합니다."""
    with open(filepath, "a", encoding="utf-8") as f:
        f.write(channel_id + "\n")


# ═══════════════════════════════════════════════════════════════
# 파일 초기화
# ═══════════════════════════════════════════════════════════════

def reset_output_files(output_path: str, completed_path: str) -> None:
    for path in [output_path, completed_path]:
        if os.path.exists(path):
            os.remove(path)
            print(f"[RESET] 삭제됨: {path}")


def ensure_csv_header(output_path: str) -> None:
    """출력 파일이 없을 때만 헤더를 작성합니다."""
    if os.path.exists(output_path):
        return
    os.makedirs(os.path.dirname(output_path), exist_ok=True) if os.path.dirname(output_path) else None
    with open(output_path, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=OUTPUT_COLUMNS)
        writer.writeheader()


# ═══════════════════════════════════════════════════════════════
# API 요청
# ═══════════════════════════════════════════════════════════════

def request_playlist_page(
    api_key: str,
    playlist_id: str,
    page_token: str = "",
    session: Optional[requests.Session] = None,
) -> Dict:
    """
    playlistItems.list API를 호출합니다.

    part=snippet만 요청합니다.
    snippet.resourceId.videoId: 영상 ID
    snippet.videoPublishedAt  : 영상 게시일
    (snippet.publishedAt은 플레이리스트 추가일이므로 videoPublishedAt 사용)
    """
    params = {
        "key":        api_key,
        "part":       "snippet",
        "playlistId": playlist_id,
        "maxResults": MAX_RESULTS,
    }
    if page_token:
        params["pageToken"] = page_token

    requester = session or requests
    response  = requester.get(API_URL, params=params, timeout=30)
    response.raise_for_status()
    return response.json()


# ═══════════════════════════════════════════════════════════════
# 응답 파싱
# ═══════════════════════════════════════════════════════════════

def parse_playlist_items(
    items: List[Dict],
    channel_id: str,
) -> List[Dict]:
    """
    playlistItems.list 응답에서 video_id와 published_at만 추출합니다.

    title/description은 수집하지 않습니다.
    AI Cover 여부 분류는 STEP 5(videos.list)에서 수행합니다.

    이 단계에서 최소 컬럼만 수집하는 이유:
      - playlistItems.list는 쿼터가 저렴 (1 unit/요청)
      - title/description까지 받으려면 videos.list 추가 호출 필요
      - STEP 5에서 videos.list를 어차피 호출하므로 중복 방지
    """
    rows: List[Dict] = []

    for item in items:
        snippet     = item.get("snippet", {}) or {}
        resource_id = snippet.get("resourceId", {}) or {}

        video_id = resource_id.get("videoId", "").strip()
        if not video_id:
            continue

        # videoPublishedAt: 영상이 실제로 게시된 날짜
        # publishedAt: 플레이리스트에 추가된 날짜 (다를 수 있음)
        published_at = snippet.get("videoPublishedAt", "") or snippet.get("publishedAt", "")

        rows.append({
            "channel_id":   channel_id,
            "video_id":     video_id,
            "published_at": published_at,
        })

    return rows


# ═══════════════════════════════════════════════════════════════
# CSV 저장
# ═══════════════════════════════════════════════════════════════

def append_rows(output_path: str, rows: List[Dict]) -> int:
    if not rows:
        return 0
    with open(output_path, "a", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=OUTPUT_COLUMNS)
        writer.writerows(rows)
    return len(rows)


# ═══════════════════════════════════════════════════════════════
# 쿼터 초과 감지
# ═══════════════════════════════════════════════════════════════

def is_quota_exceeded(exc: requests.HTTPError) -> bool:
    try:
        text = exc.response.text.lower()
    except Exception:
        text = str(exc).lower()
    return "quotaexceeded" in text


# ═══════════════════════════════════════════════════════════════
# 메인 실행
# ═══════════════════════════════════════════════════════════════

def main() -> None:
    args = parse_args()
    validate_args(args)

    if args.reset:
        print("\n[RESET] 기존 파일을 삭제하고 처음부터 수집합니다.")
        reset_output_files(args.output, args.completed)

    # 채널 로드
    channels_df   = load_channels(args.input_channels)
    total_channels = len(channels_df)

    # 완료된 채널 로드
    completed_channels = load_completed_channels(args.completed)

    # 수집할 채널 목록 (알파벳순 정렬 → 순서 일정)
    channel_rows = channels_df.sort_values('channel_id').to_dict('records')

    # CSV 헤더 초기화
    ensure_csv_header(args.output)

    pending = sum(1 for r in channel_rows if r['channel_id'] not in completed_channels)

    print(f"\n{'═'*65}")
    print(f"  채널 업로드 목록 수집 (playlistItems.list)")
    print(f"{'═'*65}")
    print(f"  총 채널 수           : {total_channels:,}개")
    print(f"  이미 완료된 채널     : {len(completed_channels):,}개 → 건너뜀")
    print(f"  이번에 수집할 채널   : {pending:,}개")
    print(f"  입력 파일            : {args.input_channels}")
    print(f"  출력 파일            : {args.output}")
    print(f"  완료 기록 파일       : {args.completed}")
    print(f"{'─'*65}")
    print(f"  ※ 쿼터: 채널당 평균 약 2~5 units 예상")
    print(f"  ※ 채널 4,000개 기준 약 8,000~20,000 units (2~3일 소요)")
    print(f"{'═'*65}\n")

    # 수집 통계
    total_requests    = 0
    total_saved       = 0
    channels_skipped  = 0
    channels_done     = 0
    channels_error    = 0

    session = requests.Session()

    try:
        for ch_idx, ch_row in enumerate(channel_rows, start=1):
            channel_id   = ch_row['channel_id']
            playlist_id  = ch_row['uploads_playlist_id']

            # ─────────────────────────────────────────────────
            # 완료된 채널 건너뛰기 (API 요청 없음)
            # ─────────────────────────────────────────────────
            if channel_id in completed_channels:
                channels_skipped += 1
                if ch_idx % 100 == 0:
                    print(f"[{ch_idx:4d}/{total_channels}] ... (건너뜀 {channels_skipped}개)")
                continue

            # ─────────────────────────────────────────────────
            # 채널 업로드 수집 (페이지네이션)
            # ─────────────────────────────────────────────────
            next_page_token = ""
            page_no         = 0
            channel_saved   = 0
            channel_error   = False

            while True:
                page_no += 1

                try:
                    data = request_playlist_page(
                        api_key      = args.api_key,
                        playlist_id  = playlist_id,
                        page_token   = next_page_token,
                        session      = session,
                    )
                    total_requests += 1

                except requests.HTTPError as exc:
                    status = getattr(exc.response, "status_code", "unknown")

                    if is_quota_exceeded(exc):
                        print(
                            f"\n[{ch_idx:4d}/{total_channels}] {channel_id[:20]}"
                            f"\n  [STOP] ❌ 쿼터 초과. 즉시 중단합니다."
                            f"\n  내일 다시 실행하면 이 채널부터 이어서 수집됩니다."
                        )
                        raise

                    # 404: 삭제된 플레이리스트 → 건너뜀
                    if status == 404:
                        print(f"[{ch_idx:4d}/{total_channels}] {channel_id[:30]} | 404 플레이리스트 없음 → 건너뜀")
                        channel_error = True
                        break

                    print(f"[{ch_idx:4d}/{total_channels}] HTTP {status} → 건너뜀")
                    channel_error = True
                    break

                except requests.RequestException as exc:
                    print(f"[{ch_idx:4d}/{total_channels}] 요청 실패: {exc} → 건너뜀")
                    channel_error = True
                    break

                items = data.get("items", [])
                if not items:
                    break

                rows  = parse_playlist_items(items, channel_id)
                saved = append_rows(args.output, rows)
                channel_saved += saved
                total_saved   += saved

                next_page_token = data.get("nextPageToken", "")
                if not next_page_token:
                    break

                time.sleep(args.sleep_seconds)

            # ─────────────────────────────────────────────────
            # 채널 완료 기록
            # 에러 없이 정상 종료됐을 때만 기록
            # ─────────────────────────────────────────────────
            if not channel_error:
                mark_channel_completed(args.completed, channel_id)
                completed_channels.add(channel_id)
                channels_done += 1

                # 100채널마다 진행상황 출력
                if ch_idx % 100 == 0 or ch_idx <= 5:
                    print(
                        f"[{ch_idx:4d}/{total_channels}] "
                        f"{ch_row.get('channel_title','')[:25]:<25} | "
                        f"저장 {channel_saved:4d}개 | "
                        f"누적 {total_saved:,}개"
                    )
            else:
                channels_error += 1

            time.sleep(args.sleep_seconds)

    except requests.HTTPError:
        pass

    finally:
        session.close()

    # ─────────────────────────────────────────────────────────
    # 최종 결과 출력
    # ─────────────────────────────────────────────────────────
    print(f"\n{'═'*65}")
    print(f"  수집 결과")
    print(f"{'═'*65}")
    print(f"  총 API 요청 수       : {total_requests:,}회")
    print(f"  총 저장 행 수        : {total_saved:,}개")
    print(f"  완료된 채널          : {channels_done:,}개")
    print(f"  건너뛴 채널          : {channels_skipped:,}개 (이미 완료)")
    print(f"  에러 채널            : {channels_error:,}개")
    print(f"  출력 파일            : {args.output}")
    print(f"{'═'*65}")

    remaining = total_channels - channels_skipped - channels_done
    if remaining > 0:
        print(
            f"\n  ⚠️  아직 {remaining}개 채널이 남아있습니다.\n"
            "  다시 실행하면 이어서 수집됩니다."
        )
    else:
        print(
            "\n  🎉 모든 채널 수집 완료!\n"
            "\n  다음 단계: python 05_fetch_uploads_meta.py\n"
            "  (채널 업로드 영상의 메타데이터 + AI Cover 재분류)\n"
        )


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(
            "\n[STOPPED] 사용자에 의해 중단되었습니다.\n"
            "현재 채널은 완료 기록되지 않았으므로\n"
            "다시 실행하면 해당 채널부터 이어서 수집됩니다."
        )
        sys.exit(1)
    except Exception as exc:
        print(f"\n[FATAL] 예상치 못한 오류: {exc}")
        sys.exit(1)
